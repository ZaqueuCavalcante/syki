{
  "Serilog": {
    "Using": [ "Serilog.Sinks.File" ],
    "MinimumLevel": { "Default": "Error" },
    "WriteTo": [
      { "Name": "File", "Args": { "path": "syki_tests_logs.txt", "rollingInterval": "Minute" } }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName" ]
  },
  "Database": {
    "ConnectionString": "Host=localhost;Username=postgres;Password=postgres;Port=5432;Database=syki-tests-db;"
  },
  "Auth": {
    "Issuer": "test",
    "Audience": "test",
    "SecurityKey": "56ef615b2e26c3b9a10dc2824238fb8b8a154ec7db4907ec6ee357ed7bb350b7",
    "ExpirationTimeInMinutes": 6000,
    "CookieSecure": false
  },
  "Jobs": {
    "CommandsPollingIntervalInSeconds": 5,
    "WebhookEventsPollingIntervalInSeconds": 5
  },
  "Email": {
    "ApiKey": "test-api-key",
    "FrontUrl": "http://localhost:3000",
    "ApiUrl": "http://localhost:5000/api/email"
  },
  "RateLimiting": {
    "QueueLimit": 0,
    "GlobalPermitLimit": 10000,
    "GlobalWindowInSeconds": 60,
    "SensitivePermitLimit": 10000,
    "SensitiveWindowInSeconds": 60
  },
  "Tracing": {
    "SamplingRatio": 1.00
  },
  "OTEL_EXPORTER_OTLP_ENDPOINT": "http://localhost:4317"
}
