{
  "Auth": {
    "Issuer": "prod",
    "Audience": "prod",
    "CookieSecure": true,
    "CookieSameSite": "Lax",
    "ExpirationTimeInMinutes": 6000
  },
  "Jobs": {
    "CommandsPollingIntervalInSeconds": 60,
    "DomainEventsPollingIntervalInSeconds": 60,
    "WebhookEventsPollingIntervalInSeconds": 1000
  },
  "Frontend": {
    "Url": "https://estud.com.br"
  },
  "Email": {
    "FrontUrl": "https://estud.com.br",
    "ApiUrl": "https://api.brevo.com/v3/smtp/email"
  },
  "SocialLogin": {
    "Google": {
      "Enabled": true,
      "ClientId": "11118065658-5v79s8jpsrtnfh78hj07113q7p407941.apps.googleusercontent.com"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": { "Default": "Information" },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName" ]
  },
  "RateLimiting": {
    "QueueLimit": 0,
    "GlobalPermitLimit": 100,
    "GlobalWindowInSeconds": 60,
    "SensitivePermitLimit": 100,
    "SensitiveWindowInSeconds": 60
  },
  "Tracing": {
    "SamplingRatio": 1.00
  }
}
